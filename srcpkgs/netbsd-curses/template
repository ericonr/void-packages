# Template file for 'netbsd-curses'
pkgname=netbsd-curses
version=0.3.1.1
revision=1
_hash=ae69600380da3e0a8ea509fee65dbd5575a34daa
wrksrc=$pkgname-$_hash
build_style=gnu-makefile
short_desc="Portable libcurses implementation from NetBSD"
maintainer="Érico Nogueira <ericonr@disroot.org>"
license="BSD-3-Clause, BSD-2-Clause"
homepage="https://github.com/sabotage-linux/netbsd-curses"
distfiles="${homepage}/archive/${_hash}.tar.gz"
checksum=e19d6df593fb5389db6a373ae7391d2b91406e4b2ee86076615bd2fd5c378ae9
conflicts="ncurses-devel"

netbsd-curses-devel_package() {
	depends="${sourcepkg}>=${version}_${revision}"
	short_desc+=" - development files"
	pkg_install() {
		vmove usr/share/man/man3
		vmove usr/include
		vmove usr/lib/pkgconfig
		vmove "usr/lib/*.a"
	}
}

netbsd-curses-progs_package() {
	short_desc+=" - executables"
	conflicts="ncurses"
	pkg_install() {
		vmove usr/bin
		vmove usr/share/man/man1
	}
}
